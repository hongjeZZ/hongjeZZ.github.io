---
layout: null
---
[{%- for post in site.posts -%}{"title":{{ post.title | jsonify }},"url":{{ post.url | relative_url | jsonify }},"date":{{ post.date | date: "%Y.%m.%d" | jsonify }},"tags":{{ post.tags | join: " " | jsonify }},"content":{{ post.content | strip_html | normalize_whitespace | truncate: 1000 | jsonify }}}{%- unless forloop.last -%},{%- endunless -%}{%- endfor -%}]
